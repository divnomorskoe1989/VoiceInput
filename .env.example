# VoiceInput recovered config
VOICEINPUT_STT_BACKEND=mock
VOICEINPUT_LOG_LEVEL=INFO
VOICEINPUT_LOG_MAX_FILE_MB=100
VOICEINPUT_LOG_BACKUP_COUNT=1
VOICEINPUT_SAMPLE_RATE=16000
VOICEINPUT_CHUNK_SIZE=1024
VOICEINPUT_RING_BUFFER_CHUNKS=256
VOICEINPUT_SILENCE_TIMEOUT_SEC=5.0
VOICEINPUT_SILENCE_RMS_THRESHOLD=500.0
VOICEINPUT_HOTKEY=ctrl+win
VOICEINPUT_HOTKEY_DEBOUNCE_MS=220
VOICEINPUT_TRANSCRIPT_DEDUPE_WINDOW_MS=900
VOICEINPUT_MICROPHONE_ENABLED=false
VOICEINPUT_MICROPHONE_DEVICE=

# Required only when VOICEINPUT_STT_BACKEND=deepgram
DEEPGRAM_API_KEY=
VOICEINPUT_DEEPGRAM_MODEL=nova-2
VOICEINPUT_DEEPGRAM_LANGUAGE=ru
VOICEINPUT_INTERIM_RESULTS=true
VOICEINPUT_INTERIM_INSERT_ENABLED=false
VOICEINPUT_SMART_FORMAT=true
VOICEINPUT_DEEPGRAM_ENDPOINTING_MS=250
